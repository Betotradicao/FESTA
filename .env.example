# ============================================================
# .env.example — Template de variáveis de ambiente
# ============================================================
# REGRA DE OURO: este arquivo (.env.example) NÃO contém valores reais.
# Copie para .env e preencha com seus valores. O .env NUNCA vai pro Git.
# ============================================================

# --- Aplicação ---
NODE_ENV=development
PORT=3000

# --- Segurança (gerar com: node scripts/generate-keys.js) ---
JWT_SECRET=
ENCRYPTION_KEY=
COOKIE_SECRET=

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=festa
DB_SSL=false

# --- Odoo ---
ODOO_URL=http://localhost:8069
ODOO_DB=festa
ODOO_USER=
ODOO_PASSWORD=

# --- APIs externas (preencher só se for usar) ---
OPENAI_API_KEY=
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=

# --- Modo dev ---
DEV_MODE=true
